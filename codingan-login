<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login – ModifikasiOri POS</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #3a6eaf 0%, #4e8ed6 45%, #6aa8e8 100%);
    position: relative;
    overflow: hidden;
  }

  body::before {
    content: '';
    position: absolute;
    width: 340px; height: 340px;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    top: -120px; left: -80px;
  }
  body::after {
    content: '';
    position: absolute;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    bottom: -60px; right: -40px;
  }

  .card {
    background: #fff;
    border-radius: 16px;
    width: 700px;
    max-width: 95vw;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    position: relative;
    z-index: 1;
    box-shadow: 0 20px 60px rgba(40, 90, 160, 0.3);
  }

  /* ── LEFT PANEL ── */
  .left-panel {
    background: linear-gradient(155deg, #ddeeff 0%, #c8e4fa 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
    gap: 18px;
  }

  .pos-badge {
    background: #3a6eaf;
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 20px;
    letter-spacing: 0.6px;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    width: 100%;
    max-width: 210px;
  }

  .icon-card {
    background: #fff;
    border-radius: 10px;
    border: 1px solid rgba(74, 144, 217, 0.18);
    padding: 14px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .icon-card span {
    font-size: 11px;
    color: #5a7a99;
    font-weight: 600;
    text-align: center;
  }

  .ic {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: #4a90d9;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ic.amber { background: #e8a030; }
  .ic.teal  { background: #2a9d8f; }
  .ic.rose  { background: #d45b79; }

  .ic svg {
    width: 16px; height: 16px;
    stroke: #fff;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .left-desc {
    font-size: 12px;
    color: #5a7a99;
    text-align: center;
    line-height: 1.6;
    max-width: 170px;
  }

  /* ── RIGHT PANEL ── */
  .right-panel {
    padding: 40px 36px 30px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #fff;
  }

  .logo-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }

  .logo-row svg { width: 36px; height: 36px; }

  .logo-text {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: 0.8px;
  }

  .sub-title {
    font-size: 12.5px;
    color: #7a9ab8;
    margin-bottom: 26px;
  }

  .field {
    position: relative;
    margin-bottom: 14px;
  }

  .field input {
    width: 100%;
    padding: 11px 38px;
    border: 1.5px solid #d5e8fb;
    border-radius: 10px;
    font-size: 13.5px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #333;
    background: #f7fbff;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .field input::placeholder { color: #aac4de; }
  .field input:focus {
    border-color: #4a90d9;
    box-shadow: 0 0 0 3px rgba(74, 144, 217, 0.13);
    background: #fff;
  }

  .field .fi-l {
    position: absolute; left: 12px; top: 50%;
    transform: translateY(-50%);
    color: #90b8d8; display: flex;
  }
  .field .fi-r {
    position: absolute; right: 12px; top: 50%;
    transform: translateY(-50%);
    color: #90b8d8; cursor: pointer; display: flex;
  }
  .field svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .remember-row {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 20px; margin-top: 2px;
  }
  .remember-row input[type="checkbox"] {
    accent-color: #4a90d9;
    width: 14px; height: 14px; cursor: pointer;
  }
  .remember-row label {
    font-size: 12.5px; color: #5a7a99; cursor: pointer;
  }

  .btn-masuk {
    width: 100%;
    padding: 13px;
    background: #3a6eaf;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 14.5px;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
    cursor: pointer;
    letter-spacing: 0.4px;
    transition: background 0.18s, transform 0.12s, box-shadow 0.18s;
    box-shadow: 0 6px 20px rgba(58, 110, 175, 0.35);
  }
  .btn-masuk:hover {
    background: #4a80c4;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(58, 110, 175, 0.45);
  }
  .btn-masuk:active { transform: translateY(0); }

  .footer {
    text-align: center;
    font-size: 11px;
    color: #aac4de;
    margin-top: 24px;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .card { grid-template-columns: 1fr; }
    .left-panel { padding: 28px 20px; }
    .right-panel { padding: 28px 24px 24px; }
  }
</style>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="card">

  <!-- LEFT PANEL -->
  <div class="left-panel">
    <span class="pos-badge">Point of Sales</span>

    <div class="icon-grid">
      <div class="icon-card">
        <div class="ic">
          <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        </div>
        <span>Penjualan</span>
      </div>
      <div class="icon-card">
        <div class="ic amber">
          <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <span>Kasir</span>
      </div>
      <div class="icon-card">
        <div class="ic teal">
          <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </div>
        <span>Laporan</span>
      </div>
      <div class="icon-card">
        <div class="ic rose">
          <svg viewBox="0 0 24 24"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
        </div>
        <span>Produk</span>
      </div>
    </div>

    <p class="left-desc">Kelola transaksi penjualan dengan mudah dan cepat</p>
  </div>

  <!-- RIGHT PANEL -->
  <div class="right-panel">
    <div class="logo-row">
      <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
        <circle cx="18" cy="18" r="17" fill="#3a6eaf"/>
        <path d="M7 26 L7 12 L18 20 L29 12 L29 26" stroke="#fff" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="logo-text">MODIFIKASI ORI</span>
    </div>
    <p class="sub-title">Masuk ke sistem kasir Anda</p>

    <div class="field">
      <span class="fi-l">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </span>
      <input type="email" placeholder="nama@email.com">
    </div>

    <div class="field">
      <span class="fi-l">
        <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      </span>
      <input type="password" placeholder="Minimal 6 karakter" id="pwdInput">
      <span class="fi-r" onclick="togglePwd()">
        <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      </span>
    </div>

    <div class="remember-row">
      <input type="checkbox" id="remember">
      <label for="remember">Ingat saya</label>
    </div>

    <button class="btn-masuk">Masuk</button>

    <p class="footer">© 2026 ModifikasiOri. All rights reserved.</p>
  </div>

</div>

<script>
  function togglePwd() {
    const inp = document.getElementById('pwdInput');
    inp.type = inp.type === 'password' ? 'text' : 'password';
  }
</script>

</body>
</html>